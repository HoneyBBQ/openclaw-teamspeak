{
  "name": "@honeybbq/openclaw-teamspeak",
  "version": "0.2.1",
  "description": "OpenClaw channel plugin for TeamSpeak — text & voice chat via the native client protocol. Compatible with TS 3, 5 & 6.",
  "license": "MIT",
  "author": "honeybbq",
  "repository": {
    "type": "git",
    "url": "https://github.com/HoneyBBQ/openclaw-teamspeak"
  },
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "oxlint .",
    "fmt": "oxfmt .",
    "fmt:check": "oxfmt --check .",
    "check": "pnpm typecheck && pnpm lint && pnpm fmt:check"
  },
  "dependencies": {
    "@evan/opus": "^1.0.3",
    "@honeybbq/teamspeak-client": "^0.1.1",
    "@sinclair/typebox": "^0.34.41",
    "mpg123-decoder": "^1.0.3",
    "ogg-opus-decoder": "^1.7.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "openclaw": "2026.4.9",
    "oxfmt": "^0.44.0",
    "oxlint": "^1.57.0",
    "typescript": "^6.0.2"
  },
  "peerDependencies": {
    "openclaw": ">=2026.3.0"
  },
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@10.32.1",
  "openclaw": {
    "extensions": [
      "./index.ts"
    ],
    "setupEntry": "./setup-entry.ts",
    "channel": {
      "id": "teamspeak",
      "label": "TeamSpeak",
      "blurb": "Connect OpenClaw to TeamSpeak servers via text & voice chat. Compatible with TS 3, 5 & 6."
    }
  }
}
